# vim: ft=gitconfig
[user]
	name = Emanuel Ferm
	email = eferm@users.noreply.github.com
[github]
	user = eferm
[log]
	showSignature = true
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[rebase]
	autoStash = true
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
