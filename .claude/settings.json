{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "effortLevel": "high",
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(bq:*)",
        "hooks": [
          {
            "type": "command",
            "command": "jq '{hookSpecificOutput: {hookEventName: \"PreToolUse\", updatedInput: (.tool_input | .command = \"CLOUDSDK_PROXY_TYPE=http \" + .command)}}'",
            "statusMessage": "Fixing bq proxy..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(gcloud:*)",
        "hooks": [
          {
            "type": "command",
            "command": "jq '{hookSpecificOutput: {hookEventName: \"PreToolUse\", updatedInput: (.tool_input | .command = \"env -u CLOUDSDK_PROXY_TYPE -u CLOUDSDK_PROXY_ADDRESS -u CLOUDSDK_PROXY_PORT \" + .command)}}'",
            "statusMessage": "Fixing gcloud proxy..."
          }
        ]
      }
    ]
  },
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "Bash(dbt:*)",
      "Bash(gh api:*)",
      "Bash(gh pr:*)",
      "Bash(gh search:*)",
      "Bash(git:*)",
      "Bash(uv:*)",
      "Glob",
      "Grep",
      "Read",
      "WebFetch",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:files.pythonhosted.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:lfs.github.com)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebSearch",
      "Write(/private/tmp/**)",
      "Write(/tmp/**)",
      "mcp__ide__getDiagnostics"
    ],
    "ask": [
      "Bash(curl * | *)",
      "Bash(gh pr create *)",
      "Bash(gh repo create *)",
      "Bash(git push *)"
    ],
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(dbt *--full-refresh*)",
      "Bash(docker rm *)",
      "Bash(find * -delete)",
      "Bash(git reset --hard *)",
      "Bash(npm publish *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(rm -rf *)",
      "Bash(wget * | *)"
    ]
  },
  "sandbox": {
    "allowUnsandboxedCommands": false,
    "autoAllowBashIfSandboxed": true,
    "enabled": true,
    "excludedCommands": [
      "dbt:*",
      "gcloud:*",
      "gh:*",
      "git:*",
      "uv:*",
      "uvx:*"
    ],
    "filesystem": {
      "allowWrite": [
        "//tmp",
        "~/.config/gcloud",
        "~/.dbt/cloud-cli"
      ]
    },
    "network": {
      "allowUnixSockets": [
        "~/.gnupg/S.gpg-agent",
        "~/.gnupg/S.keyboxd"
      ]
    }
  },
  "skipDangerousModePermissionPrompt": false,
  "statusLine": {
    "command": "bash ~/.claude/statusline.sh",
    "type": "command"
  }
}
