{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "effortLevel": "high",
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "Bash(dbt:*)",
      "Bash(gh pr:*)",
      "Glob",
      "Grep",
      "Read",
      "WebFetch",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:lfs.github.com)",
      "WebSearch",
      "Write(/private/tmp/**)",
      "Write(/tmp/**)"
    ],
    "ask": [
      "Bash(curl * | *)",
      "Bash(gh pr create *)",
      "Bash(git push *)"
    ],
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(dbt *--full-refresh*)",
      "Bash(docker rm *)",
      "Bash(find * -delete)",
      "Bash(git reset --hard *)",
      "Bash(npm publish *)",
      "Bash(rm -rf *)",
      "Bash(wget * | *)"
    ]
  },
  "sandbox": {
    "allowUnsandboxedCommands": false,
    "autoAllowBashIfSandboxed": true,
    "enabled": true,
    "excludedCommands": [
      "dbt:*",
      "gh:*"
    ],
    "filesystem": {
      "allowWrite": [
        "//tmp",
        "~/.config/gcloud",
        "~/.dbt/cloud-cli"
      ]
    },
    "network": {
      "allowUnixSockets": [
        "~/.gnupg/S.gpg-agent",
        "~/.gnupg/S.keyboxd"
      ]
    }
  },
  "skipDangerousModePermissionPrompt": false
}
